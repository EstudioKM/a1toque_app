rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null && request.auth.uid != null && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleId == 'admin') ||
        ('email' in request.auth.token && request.auth.token.email == "holaestudiokm@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOwner(userId);
    }

    match /articles/{articleId} {
      allow read: if true;
      allow update: if (resource != null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])) || isAdmin();
      allow create, delete: if isAdmin();
    }

    match /sponsorships/{id} {
      allow read: if true;
      allow update: if (resource != null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['impressions', 'clicks'])) || isAdmin();
      allow create, delete: if isAdmin();
    }

    match /brands/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /roles/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ad_slots/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /social_accounts/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /social_posts/{postId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /chat_messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || request.auth.uid == resource.data.senderId;
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid in resource.data.assignedUserIds);
    }

    match /ai_news_tasks/{taskId} {
      allow read, write: if isAuthenticated();
    }

    match /ai_social_tasks/{taskId} {
      allow read, write: if isAuthenticated();
    }

    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{path=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
